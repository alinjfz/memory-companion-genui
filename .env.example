# Echoes simplified app
# Copy to `.env.local` if you want to set local overrides.

PORT=3000
NEXT_APP_URL=http://127.0.0.1:3000

# Optional Redis (sessions). Falls back to disk-backed store in .echoes/ if unset.
REDIS_URL=redis://localhost:6379

# Local database folder (default: <project>/.echoes/)
# ECHOES_DATA_DIR=/absolute/path/to/data
AGENT_BASE_URL=http://localhost:8123

# Optional LLM providers:
# If OPENROUTER_API_KEY is set, the app tries OpenRouter first.
# Otherwise it falls back to GEMINI_API_KEY.
OPENROUTER_API_KEY=
# Default: OpenRouter free router (zero cost). Or pick a :free model slug.
OPENROUTER_MODEL=openrouter/free
# Optional: comma-separated provider order for paid models only
# OPENROUTER_PROVIDER_ORDER=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional future integrations:
LINKUP_API_KEY=
ELEVENLABS_API_KEY=
