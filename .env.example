# Echoes simplified app
# Copy to `.env.local` if you want to set local overrides.

PORT=3000
NEXT_APP_URL=http://127.0.0.1:3000

# Optional Redis (sessions). Falls back to disk-backed store in .echoes/ if unset.
REDIS_URL=redis://localhost:6379

# Local database folder (default: <project>/.echoes/)
# ECHOES_DATA_DIR=/absolute/path/to/data
AGENT_BASE_URL=http://localhost:8123

# Optional LLM providers:
# If OPENROUTER_API_KEY is set, the app tries OpenRouter first.
# Otherwise it falls back to GEMINI_API_KEY.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=amazon/nova-lite-v1
# Optional: comma-separated provider order, e.g. amazon-bedrock
# OPENROUTER_PROVIDER_ORDER=amazon-bedrock
# If you use Bedrock BYOK in OpenRouter, your AWS Bedrock key must be valid at
# https://openrouter.ai/settings/byok — disable "Always use for this provider"
# to fall back to OpenRouter credits when BYOK fails.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Optional future integrations:
LINKUP_API_KEY=
ELEVENLABS_API_KEY=
